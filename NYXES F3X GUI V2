				local ny = cf.Position.Y + RISE_SPEED * dt
				if ny >= ceilingY then break end
				cf = CFrame.new(cf.Position.X, ny, cf.Position.Z)
				remote:InvokeServer("SyncResize", {{Part=p, CFrame=cf, Size=PART_SIZE}})
				elapsed = elapsed + dt
				task.wait(dt)
			end
			pcall(function()
				if p and p.Parent then remote:InvokeServer("Remove", {p}) end
			end)
		end)
	end
	
