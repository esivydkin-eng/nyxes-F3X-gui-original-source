		local t = {}
		for _, plr in ipairs(game.Players:GetPlayers()) do
			if plr.Character then
				local h = plr.Character:FindFirstChild("Head")
				if h then t[#t+1] = h end
			end
		end
		return t
	end
	
	local function spawnParticle(remote, head, alive)
		if not head or not head.Parent then return end
		local pos = head.Position + Vector3.new(0, 2.5, 0)
		local ceilingY = head.Position.Y + HEIGHT_LIMIT
	
		local p = remote:InvokeServer("CreatePart", "Normal", CFrame.new(pos), workspace)
		if not p then return end
		remote:InvokeServer("SyncResize",    {{Part=p, CFrame=CFrame.new(pos), Size=PART_SIZE}})
