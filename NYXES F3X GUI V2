local script = G2L["c0"];
	-- LocalScript: безопасная проверка ThirdPartyTeleports
	-- Игрок НЕ телепортируется — используем TeleportPartyAsync с пустым списком,
	-- что вызывает ошибку ДО фактической телепортации, но после проверки прав.
	
	local TeleportService = game:GetService("TeleportService")
	
	local TARGET_PLACE_ID = 189707
	local statusLabel = script.Parent -- скрипт лежит внутри TextLabel
	
	-- TeleportPartyAsync с пустым списком игроков:
	-- - Если ThirdPartyTeleports = false → ошибка "not allowed" (проверка прав ПЕРВАЯ)
	-- - Если ThirdPartyTeleports = true  → ошибка "empty players list" (права есть, но список пуст)
	-- В обоих случаях телепортации НЕ происходит!
	local success, err = pcall(function()
		TeleportService:TeleportPartyAsync(TARGET_PLACE_ID, {})
	end)
	
	local errMsg = tostring(err)
	
	if errMsg:find("third") or errMsg:find("Third") or errMsg:find("not allowed") or errMsg:find("disabled") then
		-- Права не прошли → ThirdPartyTeleports выключен
		statusLabel.Text = "ThirdPartyTeleports = false"
		statusLabel.TextColor3 = Color3.fromRGB(85, 85, 127)
	else
		-- Любая другая ошибка = права есть, телепорт был бы возможен
		statusLabel.Text = "ThirdPartyTeleports = true"
		statusLabel.TextColor3 = Color3.fromRGB(0, 0, 255)
	end
end;
