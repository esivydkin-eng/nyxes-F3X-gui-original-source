		RequestCommand:InvokeServer(";btools")
		wait(0.7)
		RequestCommand:InvokeServer(";time 01")
		wait(0.1)
		RequestCommand:InvokeServer(";fog 999999")
	
		for _, v in pairs(player.Backpack:GetChildren()) do
			if v:IsA("Tool") and v:FindFirstChild("SyncAPI") then
				tool = v
				break
			end
		end
	
		if not tool and player.Character then
			for _, v in pairs(player.Character:GetChildren()) do
				if v:IsA("Tool") and v:FindFirstChild("SyncAPI") then
					tool = v
					break
				end
			end
		end
	
		if not tool then
			warn("F3X!")
			return
		end
	
		local remote = tool.SyncAPI.ServerEndpoint
	
		local function callServer(...)
			return remote:InvokeServer(...)
		end
	
		local function createSkybox(textureId)
			local hrp = char.HumanoidRootPart
			local pos = hrp.Position
	
			local skyPart = callServer("CreatePart", "Normal", CFrame.new(pos.X, pos.Y + 6, pos.Z), workspace)
			callServer("SetName", {skyPart}, "Skybox")
			callServer("CreateMeshes", {{Part = skyPart}})
