local function saveOriginalData()
    for _, name in pairs(requiredParts) do
        local part = Workspace:FindFirstChild(name)
        if part and part:IsA("BasePart") then
            local textures = {}
            local decals = {}
            
            for _, child in pairs(part:GetChildren()) do
                if child:IsA("Texture") then
                    textures[child.Face] = {
                        Texture = child.Texture,
                        Transparency = child.Transparency,
                        Color3 = child.Color3,
                        Offset = child.Offset,
                        StudsPerTileU = child.StudsPerTileU,
                        StudsPerTileV = child.StudsPerTileV
                    }
                elseif child:IsA("Decal") and name == "SpawnLocation" then
                    decals[child.Face] = {
                        Texture = child.Texture,
                        Transparency = child.Transparency,
                        Color3 = child.Color3,
                        ZIndex = child.ZIndex
                    }
                elseif child:IsA("Decal") then
                    decals[child.Face] = {
                        Texture = child.Texture,
                        Transparency = child.Transparency,
                        Color3 = child.Color3,
                        ZIndex = child.ZIndex
                    }
                end
            end
            
            originalData[name] = {
                position = part.Position,
                size = part.Size,
                cframe = part.CFrame,
                color = part.Color,
                material = part.Material,
                transparency = part.Transparency,
                textures = textures,
                decals = decals
            }
        end
    end
end

