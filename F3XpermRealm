        RequestCommand:InvokeServer(";music 90256750115455 , ;pitch 1.1 , ;volume 10")
        return
    end
    
    if sound.Playing == false then
        sound:Stop()
        task.wait(0.3)
        RequestCommand:InvokeServer(";music 90256750115455 , ;pitch 1.1 , ;volume 10")
        return
    end
    
    if sound.SoundId ~= "rbxassetid://90256750115455" then
        sound:Stop()
        task.wait(0.3)
        RequestCommand:InvokeServer(";music 90256750115455 , ;pitch 1.1 , ;volume 10")
        return
    end
    
    if sound.PlaybackSpeed ~= 1.1 then
        RequestCommand:InvokeServer(";pitch 1.1")
    end
end

