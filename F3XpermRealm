local function checkSpawnDecal()
    local spawn = Workspace:FindFirstChild("SpawnLocation")
    if not spawn or not spawn:IsA("BasePart") then
        loadMap()
        return false
    end
    
    local decals = {}
    for _, child in pairs(spawn:GetChildren()) do
        if child:IsA("Decal") and child.Face == Enum.NormalId.Top then
            table.insert(decals, child)
        end
    end
    
    if #decals ~= 1 then
        loadMap()
        return false
    end
    
    local decal = decals[1]
    if decal.Texture ~= "rbxasset://textures/SpawnLocation.png" then
        loadMap()
        return false
    end
    
    return true
end

local function checkTexturesAndDecals(part, name)
    if name == "SpawnLocation" then
        return checkSpawnDecal()
    end
    
    local saved = originalData[name]
    if not saved then return false end
    
    local currentTextures = {}
    local currentDecals = {}
    
    for _, child in pairs(part:GetChildren()) do
        if child:IsA("Texture") then
            local key = tostring(child.Face)
            currentTextures[key] = {
                Texture = child.Texture,
                Transparency = child.Transparency,
                Color3 = child.Color3,
                Offset = child.Offset,
                StudsPerTileU = child.StudsPerTileU,
                StudsPerTileV = child.StudsPerTileV
            }
        elseif child:IsA("Decal") then
            local key = tostring(child.Face)
            currentDecals[key] = {
                Texture = child.Texture,
                Transparency = child.Transparency,
                Color3 = child.Color3,
                ZIndex = child.ZIndex
            }
        end
    end
    
    local function compareTables(t1, t2)
        if not t1 and not t2 then return true end
        if not t1 or not t2 then return false end
        
        for k, v in pairs(t1) do
            if not t2[k] then return false end
            for prop, val in pairs(v) do
                if t2[k][prop] ~= val then return false end
            end
        end
        
        for k, v in pairs(t2) do
            if not t1[k] then return false end
        end
        
        return true
    end
    
    if not compareTables(saved.textures, currentTextures) then
        return false
    end
    
    if not compareTables(saved.decals, currentDecals) then
        return false
    end
    
    return true
end

local function checkParts()
    if not mapLoaded then return end
    
    for name, data in pairs(originalData) do
        local current = Workspace:FindFirstChild(name)
        if not current or not current:IsA("BasePart") then
            loadMap()
            return
        end
        
        if (current.Position - data.position).Magnitude > 3 then
            loadMap()
            return
        end
        
        if current.Size ~= data.size then
            loadMap()
            return
        end
        
        if current.Color ~= data.color then
            loadMap()
            return
        end
        
        if current.Material ~= data.material then
            loadMap()
            return
        end
        
        if current.Transparency ~= data.transparency then
            loadMap()
            return
        end
        
        if not checkTexturesAndDecals(current, name) then
            loadMap()
            return
        end
    end
end

local function checkMusic()
