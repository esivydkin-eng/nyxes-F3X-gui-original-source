local TUBE_POS = Vector3.new(57850000, 404, 5556000)
local SPAWN_POS = TUBE_POS + Vector3.new(0, -15, 0)

local function makePart(cf, size, color, material, canCollide)
	material = material or Enum.Material.SmoothPlastic
	canCollide = canCollide ~= false
	local ok, part = pcall(function()
		return ep:InvokeServer("CreatePart", "Normal", cf, workspace)
	end)
	if not ok or not part then
		warn("loader err")
		return nil
	end
	pcall(function() ep:InvokeServer("SyncResize",    {{Part=part, CFrame=part.CFrame, Size=size}}) end)
	pcall(function() ep:InvokeServer("SyncColor",     {{Part=part, Color=color}}) end)
	pcall(function() ep:InvokeServer("SyncMaterial",  {{Part=part, Material=material}}) end)
	pcall(function() ep:InvokeServer("SyncAnchor",    {{Part=part, Anchored=true}}) end)
	pcall(function() ep:InvokeServer("SyncCollision", {{Part=part, CanCollide=canCollide}}) end)
	return part
end

